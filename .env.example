# ============================================================
# RevOps Command Center — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Google Sheets (service account — already set up in Phase 1)
GOOGLE_SHEET_ID=1d3QJCXcTNwWOI3xIAqPJ4pvx0AhdyzKk3NpK6mvKVUQ

# Google OAuth2 (for Gmail + Calendar — set by auth_setup.py)
# Get client_id and client_secret from Google Cloud Console:
#   https://console.cloud.google.com/apis/credentials
#   Project: revops-command-center-499414 → OAuth 2.0 Client IDs → Desktop app
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=   # set automatically by auth_setup.py
GOOGLE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token

# Slack (optional — bot token or user token)
# Get from: https://api.slack.com/apps → your app → OAuth & Permissions
SLACK_TOKEN=

# Anthropic (for action generation)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
